    import ingenieur
    diff = body.get("diff")
    if not diff and body.get("id"):
        pr = ingenieur.get(body["id"])
        diff = pr.get("diff") if pr else None
    insts = body.get("instruments") or ["BTC/USD", "ETH/USD", "EUR_USD"]
    return ingenieur.backtest_impact(diff or {}, insts)


