# Copier ce fichier en .env pour le développement local :  cp .env.example .env
# En production sur Hostinger : définir ces mêmes variables dans le panneau
# d'environnement du serveur (ne pas committer de vrai .env).
#
# NE JAMAIS committer de vraies clés. Ajouter .env au .gitignore.

# --- OANDA ---
# Commencez TOUJOURS avec un compte practice (démo).
OANDA_TOKEN=votre-token-practice-ici
# Vous n'avez que la clé API ? Récupérez l'ID avec :  python oanda_accounts.py
OANDA_ACCOUNT_ID=101-002-xxxxxxx-001
OANDA_ENV=practice

# Verrou d'exécution réelle. Laisser "false" pendant tout le développement.
OANDA_LIVE_TRADING=false

# Devise du compte (vous : CAD).
ACCOUNT_CURRENCY=CAD

# --- Couche news (optionnel) ---
# Clé d'API de calendrier économique (ex : Finnhub, offre gratuite).
FINNHUB_KEY=
